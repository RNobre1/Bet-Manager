# Database — required in prod (GH Actions injects from secrets).
# Local dev/test against a docker Postgres on :5433.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
DATABASE_URL_TEST=postgres://adam:senha@localhost:5433/adam_stats_test

# Adamchoi/choistats — token is public/static, embedded in the SPA.
SCRAPER_TARGET_BASE_URL=https://www.adamchoi.co.uk
ADAMCHOI_API_TOKEN=45834886-68b3-11eb-99f4-9e36325824ad

# League whitelist — CSV of canonical slugs (defines which detail pages are
# fetched). Defaults to the top European/Brazilian leagues if unset.
SCRAPER_LEAGUE_SLUGS=england-premier-league,spain-la-liga,italy-serie-a,germany-bundesliga,france-ligue-1,portugal-portugese-liga-nos,brazil-serie-a,brazil-serie-b,netherlands-tweede-divisie,england-championship,usa-us-mls

# Concurrency for detail fetching. HTTP-direct path (default) handles 4+ fine.
SCRAPER_DETAIL_CONCURRENCY=4

# Playwright fallback — only set when forcing listing via Playwright SPA render
# (SCRAPER_USE_PLAYWRIGHT_LIST=1) or detail via legacy DetailPageFetcher.
# PLAYWRIGHT_CLI_EXECUTABLE_PATH=/tmp/pw-ruby-driver/node_modules/.bin/playwright

# Observability — healthchecks.io free tier. Ping /start, /, /fail.
HEALTHCHECKS_URL=

# OpenRouter — used by the API (Next.js routes), not by the scraper.
# Listed here for parity with the Cron workflow secrets.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v3.2
